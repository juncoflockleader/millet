{
  "id": "sanguosha-eight-player-board",
  "version": "0.1.0",
  "kind": "board_layout",
  "metadata": {
    "name": "Sanguosha Eight Player Board",
    "description": "Schema-backed 6-8 player identity-game table layout with seat ring, shared deck/discard, judgment, equipment, and active-player hand regions."
  },
  "logicalSize": {
    "width": 1280,
    "height": 720
  },
  "scaling": {
    "mode": "fit_viewport",
    "minScale": 0.18,
    "maxScale": 1
  },
  "tokens": {
    "table": {
      "seatWidth": 172,
      "seatHeight": 104,
      "sideSeatWidth": 150,
      "sideSeatHeight": 120,
      "centerWidth": 304,
      "centerHeight": 164
    },
    "player": {
      "handHeight": 136,
      "equipmentHeight": 74,
      "judgmentHeight": 44
    },
    "card": {
      "width": 88,
      "artHeight": 42
    }
  },
  "propertyDisplay": {
    "slots": [
      { "id": "top-left", "label": "Upper Left Corner", "objectTypes": ["card", "equipment", "identity"] },
      { "id": "top-right", "label": "Upper Right Corner", "objectTypes": ["card", "equipment", "identity"] },
      { "id": "bottom-left", "label": "Lower Left Corner", "objectTypes": ["equipment"] },
      { "id": "bottom-right", "label": "Lower Right Corner", "objectTypes": ["equipment"] },
      { "id": "suit-point", "label": "Suit And Point Corner", "objectTypes": ["card"] },
      { "id": "role-corner", "label": "Identity Role Corner", "objectTypes": ["identity"] }
    ],
    "icons": [
      { "id": "mana", "label": "Resource" },
      { "id": "sword", "label": "Attack Range" },
      { "id": "heart", "label": "Health" },
      { "id": "durability", "label": "Durability" },
      { "id": "suit", "label": "Suit" },
      { "id": "rank", "label": "Point" },
      { "id": "faction", "label": "Identity Faction" }
    ]
  },
  "regions": [
    {
      "id": "seat_1_lord",
      "kind": "hero",
      "ownerScope": "player",
      "label": "Seat 1 / Lord",
      "geometry": { "x": 554, "y": 596, "width": 172, "height": 104 },
      "widgetId": "identity-player-panel",
      "accepts": ["character", "identity", "player"],
      "targetable": true,
      "dropBehavior": "select_player_target",
      "overflow": "compact",
      "visibleTo": "public"
    },
    {
