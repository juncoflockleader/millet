{
  "id": "sample-basic-trio",
  "version": "0.1.0",
  "metadata": {
    "name": "Basic Trio",
    "description": "A behavior-equivalent early-basic-set dogfood for Mage, Warrior, and Priest style classes using original Millet content."
  },
  "playerConfig": {
    "minPlayers": 2,
    "maxPlayers": 2
  },
  "zones": [
    { "id": "hand", "zoneType": "hand", "scope": "player" },
    { "id": "deck", "zoneType": "deck", "scope": "player" },
    { "id": "board", "zoneType": "board", "scope": "player", "capacity": 7 },
    { "id": "weapon", "zoneType": "weapon", "scope": "player", "capacity": 1 },
    { "id": "discard", "zoneType": "discard", "scope": "match" },
    { "id": "graveyard", "zoneType": "graveyard", "scope": "match" }
  ],
  "resources": [
    { "id": "health", "defaultMax": 30 },
    { "id": "mana", "defaultMax": 10 },
    { "id": "armor", "defaultCurrent": 0 },
    { "id": "heroAttack", "defaultCurrent": 0 },
    { "id": "heroFrozen", "defaultCurrent": 0 },
    { "id": "fatigue", "defaultCurrent": 0 }
  ],
  "turnGraph": [
    "turn_start",
    "resource_refresh",
    "draw",
    "main",
    "turn_end"
  ],
  "cardCatalog": "card-catalog.json",
  "ui": {
